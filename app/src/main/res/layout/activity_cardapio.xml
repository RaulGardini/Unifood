<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/navy"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cardapio"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- CONTEÚDO -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- BOTÃO ADICIONAR AO CARDÁPIO -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnAdicionarCardapio"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_btn_finalizar"
                android:text="Adicionar ao cardapio"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:layout_marginBottom="14dp"/>

            <!-- CATEGORIAS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:id="@+id/tabLanches"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_tab_active"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="Lanches"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tabBebidas"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_tab_inactive"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="Bebidas"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tabSobremesas"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_tab_inactive"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="Sobremesas"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp"/>

                <!-- Botão + -->
                <TextView
                    android:id="@+id/btnAddCategoria"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/bg_badge"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- ITEM 1 - Kalzone de frango -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_stat"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <!-- Foto -->
                <LinearLayout
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="@drawable/bg_foto_comida"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="foto da\ncomida"
                        android:textColor="#999999"
                        android:textSize="10sp"
                        android:gravity="center"/>
                </LinearLayout>

                <!-- Info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Kalzone de frango"
                            android:textColor="@color/text_dark"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_disponivel"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"
                            android:text="disponível"
                            android:textColor="#FFFFFF"
                            android:textSize="9sp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="descrição do item..."
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="R$ 12,00"
                            android:textColor="@color/orange"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/btnEditarItem"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_btn_edit_item"
                            android:gravity="center"
                            android:text="✏️"
                            android:textSize="16sp"
                            android:layout_marginEnd="6dp"/>

                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_btn_delete_item"
                            android:gravity="center"
                            android:text="🗑️"
                            android:textSize="16sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ITEM 2 - Kalzone de carne -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_stat"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Foto -->
                <LinearLayout
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="@drawable/bg_foto_comida"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="foto da\ncomida"
                        android:textColor="#999999"
                        android:textSize="10sp"
                        android:gravity="center"/>
                </LinearLayout>

                <!-- Info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Kalzone de carne"
                            android:textColor="@color/text_dark"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_indisponivel"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"
                            android:text="indisponível"
                            android:textColor="#FFFFFF"
                            android:textSize="9sp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="descrição do item..."
                        android:textColor="@color/text_muted"
                        android:textSize="12sp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="R$ 12,00"
                            android:textColor="@color/orange"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_btn_edit_item"
                            android:gravity="center"
                            android:text="✏️"
                            android:textSize="16sp"
                            android:layout_marginEnd="6dp"/>

                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_btn_delete_item"
                            android:gravity="center"
                            android:text="🗑️"
                            android:textSize="16sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAV BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:elevation="8dp"
        android:gravity="center">

        <LinearLayout
            android:id="@+id/navDashboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <View
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="@android:color/transparent"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dashboard e Pedidos"
                android:textColor="#888888"
                android:textSize="12sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navCardapio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <View
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="#FF6B00"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cardapio"
                android:textColor="#FF6B00"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
