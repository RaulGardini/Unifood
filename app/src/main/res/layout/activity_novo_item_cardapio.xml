<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- HEADER -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/navy"
        android:padding="20dp">

        <TextView
            android:id="@+id/btnVoltar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_btn_finalizar"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:text="Voltar"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cardapio"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Novo item"
                android:textColor="#B0C4DE"
                android:textSize="13sp"/>
        </LinearLayout>
    </RelativeLayout>

    <!-- CONTEÚDO -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- CATEGORIA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Categoria"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/tabLanches"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_tab_active"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="Lanches"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tabBebidas"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_tab_inactive"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="Bebidas"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tabSobremesas"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:background="@drawable/bg_tab_inactive"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="Sobremesas"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/btnAddCategoria"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/bg_badge"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- FOTO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Foto"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"
                android:layout_gravity="center_horizontal"/>

            <LinearLayout
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:background="@drawable/bg_foto_comida"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="foto da\ncomida"
                    android:textColor="#999999"
                    android:textSize="12sp"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- NOME -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nome"
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/edtNome"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_feedback"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>

            <!-- DESCRIÇÃO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descrição"
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/edtDescricao"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@drawable/bg_input_feedback"
                android:gravity="top|start"
                android:paddingHorizontal="12dp"
                android:paddingTop="10dp"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>

            <!-- VALOR -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Valor"
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/edtValor"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_feedback"
                android:inputType="numberDecimal"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="20dp"/>

            <!-- BOTÃO -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnAdicionar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_btn_finalizar"
                android:text="Adicionar"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"/>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAV BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:elevation="8dp"
        android:gravity="center">

        <LinearLayout
            android:id="@+id/navDashboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <View
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="@android:color/transparent"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dashboard e Pedidos"
                android:textColor="#888888"
                android:textSize="12sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navCardapio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <View
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="#FF6B00"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cardapio"
                android:textColor="#FF6B00"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
