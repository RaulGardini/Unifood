<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- HEADER -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/navy"
        android:padding="20dp">

        <TextView
            android:id="@+id/btnVoltar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_btn_finalizar"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:text="Voltar"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Enviar FeedBack"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"/>
    </RelativeLayout>

    <!-- CONTEÚDO -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- AVALIAÇÃO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Como você avalia o aplicativo?"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/star1"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:gravity="center"
                    android:text="★"
                    android:textColor="#F5A623"
                    android:textSize="32sp"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:id="@+id/star2"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:gravity="center"
                    android:text="★"
                    android:textColor="#F5A623"
                    android:textSize="32sp"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:id="@+id/star3"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:gravity="center"
                    android:text="★"
                    android:textColor="#F5A623"
                    android:textSize="32sp"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:id="@+id/star4"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:gravity="center"
                    android:text="★"
                    android:textColor="#F5A623"
                    android:textSize="32sp"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:id="@+id/star5"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:gravity="center"
                    android:text="★"
                    android:textColor="#E0E0E0"
                    android:textSize="32sp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Muito bom!"
                android:textColor="@color/orange"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"/>

            <!-- O QUE MAIS GOSTOU -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="O que você mais gostou?"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tagInterface"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_tag_selected"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="Interface"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tagVelocidade"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_tag_unselect"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="Velocidade"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tagVariedade"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_tag_unselect"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="Variedade"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tagPreco"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_tag_unselect"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="Preço"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tagSuporte"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_tag_unselect"
                    android:gravity="center"
                    android:paddingHorizontal="16dp"
                    android:text="Suporte"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- COMENTÁRIO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Deixe um comentário"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/edtComentario"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="@drawable/bg_input_feedback"
                android:gravity="top|start"
                android:hint="Adicionar comentário..."
                android:textColorHint="#AAAAAA"
                android:padding="14dp"
                android:textSize="14sp"
                android:layout_marginBottom="20dp"/>

            <!-- BOTÃO ENVIAR -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnEnviar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_btn_finalizar"
                android:text="Enviar FeedBack"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"/>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAV BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:elevation="8dp"
        android:gravity="center">

        <LinearLayout
            android:id="@+id/navInicio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <View
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="@android:color/transparent"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inicio"
                android:textColor="#888888"
                android:textSize="13sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPedidos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <View
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="@android:color/transparent"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pedidos"
                android:textColor="#888888"
                android:textSize="13sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <View
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="#FF6B00"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perfil"
                android:textColor="#FF6B00"
                android:textSize="13sp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
