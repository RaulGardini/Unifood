<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="#123B63"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="16dp">

            <!-- BOTÃO VOLTAR -->
            <TextView
                android:id="@+id/btnVoltar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Voltar"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:background="#FF6B00"
                android:padding="6dp"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true"/>

            <!-- TÍTULO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Novo estabelecimento"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_centerInParent="true"/>
        </RelativeLayout>

        <!-- CONTEÚDO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- FOTO -->
            <TextView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_foto"
                android:text="foto do estabelecimento"
                android:textColor="#333333"
                android:gravity="center"
                android:textAlignment="center"/>

            <!-- NOME -->
            <TextView
                android:text="Nome"
                android:textSize="14sp"
                android:layout_marginTop="20dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/etNome"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input2"
                android:padding="12dp"
                android:layout_marginTop="6dp"/>

            <!-- EMAIL -->
            <TextView
                android:text="Email"
                android:textSize="14sp"
                android:layout_marginTop="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input"
                android:padding="12dp"
                android:layout_marginTop="6dp"/>

            <!-- SENHA -->
            <TextView
                android:text="Senha"
                android:textSize="14sp"
                android:layout_marginTop="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/etSenha"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input"
                android:padding="12dp"
                android:layout_marginTop="6dp"
                android:inputType="textPassword"/>

            <!-- TEXTO ERRO -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="A senha deve ter ao menos 10 caracteres, um símbolo ou número e uma letra maiúscula."
                android:textColor="#FF0000"
                android:textSize="12sp"
                android:layout_marginTop="6dp"/>

            <!-- BOTÃO CADASTRAR -->
            <Button
                android:id="@+id/btnCadastrar"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Cadastrar"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#FF6B35"
                android:layout_marginTop="30dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>