<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Seu pedido chegou!"
        android:textColor="@color/navy"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Faça uma avaliação:"
        android:textColor="@color/navy"
        android:textSize="15sp"
        android:layout_marginBottom="12dp"/>

    <RatingBar
        android:id="@+id/ratingBar"
        style="?android:attr/ratingBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:numStars="5"
        android:stepSize="1"
        android:rating="5"
        android:progressTint="#FFB300"
        android:progressBackgroundTint="#CCCCCC"
        android:secondaryProgressTint="#FFB300"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etComentario"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_input_comentario"
        android:hint="Adicionar comentário..."
        android:textColorHint="#AAAAAA"
        android:textSize="13sp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:inputType="text"
        android:layout_marginBottom="20dp"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnEnviar"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:background="@drawable/bg_btn_finalizar"
        android:text="Enviar"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textAllCaps="false"/>

</LinearLayout>
